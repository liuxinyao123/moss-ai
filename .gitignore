# Dependencies
node_modules/

# 内嵌 ClawX（clawx/）— 仅提交源码，不提交依赖与构建产物
clawx/node_modules/
clawx/dist/
clawx/dist-electron/
clawx/release/
clawx/.pnpm-store/
clawx/coverage/
clawx/playwright-report/
clawx/test-results/
clawx/build/
clawx/artifacts/

# Logs & runtime
logs/
*.log
*.pid

# Secrets & local env
.env
.env.*
!.env.example
backend/.env

# Local databases & indexes
*.db
memory-index/

# Runtime agent workspaces（含嵌套 .git 与个人数据，不纳入本仓库）
agents/*
!agents/.gitkeep
!agents/README.md

# User uploads & cache
uploads/*
!uploads/.gitkeep
.cache/
.home/

# Demo / automation artifacts (large)
demo-scene/output/
demo-scene/browser-profiles/
demo-scene/browser-run-profiles/

