{
  "id": "weather-skill-v1.0.0",
  "name": "天气查询",
  "version": "1.0.0",
  "description": "查询当前天气和天气预报",
  "author": "DSclaw Team",
  "license": "MIT",
  "repository": "https://github.com/moss-ai/skills/weather",
  
  "entry_point": "skill.js",
  "dependencies": ["axios", "moment"],
  
  "permissions": {
    "network": true,
    "file_system": false,
    "memory_access": true,
    "agent_communication": true,
    "permission_level": 1
  },
  
  "triggers": [
    {
      "type": "keyword",
      "patterns": ["天气", "天气预报", "温度", "气温", "湿度", "风向"]
    },
    {
      "type": "intent",
      "intent": "weather_query"
    }
  ],
  
  "parameters": [
    {
      "name": "location",
      "type": "string",
      "description": "城市名称或地址",
      "required": true,
      "example": "北京"
    },
    {
      "name": "days",
      "type": "number",
      "description": "预报天数",
      "default": 3,
      "min": 1,
      "max": 7
    },
    {
      "name": "units",
      "type": "string",
      "description": "温度单位",
      "default": "celsius",
      "enum": ["celsius", "fahrenheit"]
    }
  ],
  
  "capabilities": [
    "current_weather",
    "weather_forecast",
    "temperature_conversion",
    "weather_alerts"
  ],
  
  "metadata": {
    "category": "utility",
    "tags": ["weather", "forecast", "temperature", "humidity"],
    "compatibility": ["nodejs>=16.0.0"],
    "created_at": "2026-03-18T08:00:00Z",
    "last_updated": "2026-03-18T08:00:00Z"
  },
  
  "examples": [
    {
      "input": "北京天气怎么样？",
      "output": "当前北京天气：晴，气温 18°C，湿度 45%，西北风 3级。"
    },
    {
      "input": "上海未来3天天气预报",
      "output": "上海未来3天天气预报：..."
    }
  ]
}