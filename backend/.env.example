## 公网回调域名（生产环境必须配；本地可不填，会自动用请求的 Host 计算）
MOSS_PUBLIC_BASE_URL=

## 你自己的登录态（JWT）密钥：必须设置，否则回调会报错
MOSS_AUTH_JWT_SECRET=replace-with-a-long-random-string
MOSS_AUTH_JWT_ISSUER=moss-ai

## 飞书 SSO（自建应用）
FEISHU_CLIENT_ID=
FEISHU_CLIENT_SECRET=
FEISHU_SCOPE=auth:user.id:read user_profile offline_access

## 钉钉 SSO（OAuth2 网页应用/第三方应用）
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_SCOPE=openid

## 企业微信 SSO（扫码登录）
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_CORP_SECRET=

